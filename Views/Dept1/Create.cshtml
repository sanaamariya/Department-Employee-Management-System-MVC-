@model crudapp.Models.Dept
@{
    ViewBag.Title="Create";
}
<div class="welcome-box text-start">
<h2 class="mb-4 text-center">Create Department</h2>

@using(Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="form-horizontal">
        
        <hr/>
        @Html.ValidationSummary(true,"",new{@class="text-danger"})

        <div class="row mb-3 align-items-center">
            
           @Html.LabelFor(model=>model.dno, htmlAttributes : new {@class="control-label me-2"})
           <div class="col-md-10">
            @Html.EditorFor(model => model.dno, new { htmlAttributes = new {@class ="form-control"}})
            @Html.ValidationMessageFor(model =>model.dno,"",new {@class = "text-danger"})

           </div>
        </div>

        <div class="row mb-3 align-items-center ">
            @Html.LabelFor(model => model.dna, htmlAttributes: new{ @class = "control-label me-3"})
            <div class="col-md-10">
                @Html.EditorFor(model =>model.dna, new {htmlAttributes = new {@class ="form-control"}})
                @Html.ValidationMessageFor(model => model.dna,"",new {@class = "text-danger"})
            </div>
        </div>

        <div class="row mb-3 align-items-center">
            @Html.LabelFor(model => model.dloc, htmlAttributes: new {@class="control-label me-3"})
            <div class="col-md-10 ">
                @Html.EditorFor(model => model.dloc, new {htmlAttributes = new {@class ="form-control"}})
                @Html.ValidationMessageFor(model =>model.dloc,"", new {@class="text-danger"})

            </div>
        </div>
        <div class="row mt-4">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Create" class="btn btn-primary"/>
                <a class="btn btn-secondary" href="@Url.Action("Index")">Back to List</a>
            </div>
        </div>
    </div>
}
</div>
 
 @section Scripts{
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
 }